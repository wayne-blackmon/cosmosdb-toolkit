// tsconfig.json

{
  "compilerOptions": {
    "module": "commonjs",
    "target": "es2020",
    "outDir": "out",
    "rootDir": "src",

    "strict": true,
    "sourceMap": true,
    "inlineSources": true,

    "esModuleInterop": true,
    "resolveJsonModule": true,

    "moduleResolution": "node",
    "skipLibCheck": true,

    // VS Code extension specific
    "types": ["node", "vscode"]
  },

  "include": ["src/**/*"],

  "exclude": ["node_modules", ".vscode-test"]
}
