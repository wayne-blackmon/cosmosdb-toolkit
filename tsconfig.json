// tsconfig.json

{
  "compilerOptions": {
    "module": "commonjs",
    "target": "es2020",
    "outDir": "out",
    "rootDir": "src",

    "strict": true,
    "sourceMap": true,
    "inlineSources": true,

    "esModuleInterop": true,
    "resolveJsonModule": true,

    "moduleResolution": "bundler",
    "skipLibCheck": true,

    "types": ["node", "vscode"],
    "typeRoots": ["./src/types", "./node_modules/@types"]
  },

  "include": ["src/**/*"],

  "exclude": ["node_modules", ".vscode-test"]
}
