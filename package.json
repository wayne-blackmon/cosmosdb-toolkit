{
  "name": "cosmosdb-toolkit",
  "displayName": "Cosmos DB Toolkit",
  "description": "Developer tooling for Azure Cosmos DB server-side JavaScript (stored procedures, triggers, UDFs).",
  "version": "0.2.1",
  "publisher": "wayne-blackmon",
  "icon": "assets/icon/icon-dark.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/wayneblackmon/cosmosdb-toolkit.git"
  },
  "engines": {
    "vscode": "^1.109.0"
  },
  "categories": [
    "Programming Languages",
    "Other"
  ],
  "activationEvents": [
    "onLanguage:javascript",
    "onLanguage:typescript"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "cosmosdb-toolkit.openScratchpad",
        "category": "Cosmos DB",
        "title": "Cosmos DB: Open Scratchpad",
        "icon": {
          "light": "assets/icon/icon-light.png",
          "dark": "assets/icon/icon-dark.png"
        }
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "test": "npm run compile && node ./out/test/runTest.js",
    "verify": "npm run compile && npm run lint && node ./out/test/runTest.js",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@types/mocha": "^10.0.0",
    "@types/node": "^18.0.0",
    "@types/vscode": "^1.109.0",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "@vscode/test-electron": "^2.3.0",
    "eslint": "^10.0.2",
    "glob": "^10.3.0",
    "mocha": "^10.0.0",
    "prettier": "^3.8.1",
    "typescript": "^5.0.0"
  },
  "overrides": {
    "serialize-javascript": "^7.0.5"
  }
}

