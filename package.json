{
  "name": "cosmosdb-toolkit",
  "displayName": "Cosmos DB Toolkit",
  "description": "Developer tooling for Azure Cosmos DB server-side JavaScript (stored procedures, triggers, UDFs).",
  "version": "0.1.2",
  "publisher": "wayne-blackmon",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Other"
  ],
  "activationEvents": [
    "onLanguage:javascript",
    "onLanguage:typescript"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "cosmosdb-toolkit.openScratchpad",
        "title": "Cosmos DB: Open Scratchpad"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "test": "npm run compile && node ./out/test/runTest.js",
    "verify": "npm run compile && npm run lint && node ./out/test/runTest.js",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.0",
    "@types/node": "^18.0.0",
    "@types/vscode": "^1.109.0",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "@vscode/test-electron": "^2.3.0",
    "eslint": "^10.0.2",
    "glob": "^10.3.0",
    "mocha": "^10.0.0",
    "typescript": "^5.0.0"
  }
}

